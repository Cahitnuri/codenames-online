# For local dev, leave empty (Vite proxy handles it)
VITE_SERVER_URL=

# For production deployment, set to your server URL:
# VITE_SERVER_URL=https://your-server.railway.app

# Supabase (required for user accounts)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here
